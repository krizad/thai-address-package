{
  "name": "@krizad/thai-location-kit",
  "version": "1.0.4",
  "description": "Lightweight Thai address lookup engine",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "files": [
    "dist",
    "data"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "thai",
    "address",
    "thailand",
    "zipcode",
    "province",
    "district",
    "subDistrict",
    "thai-address",
    "thai-location",
    "location",
    "postal-code",
    "postcode",
    "tambon",
    "amphoe",
    "changwat",
    "bangkok",
    "ที่อยู่",
    "ประเทศไทย",
    "รหัสไปรษณีย์",
    "ตำบล",
    "อำเภอ",
    "จังหวัด",
    "autocomplete"
  ],
  "author": "KriZad",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KriZad/thai-address-package.git"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
