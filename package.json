{
  "name": "@krizad/thai-address-helper",
  "version": "1.0.0",
  "description": "Lightweight Thai address lookup engine — search by sub-district, district, province, or zipcode with cascading dropdown support. Works in Node.js and the browser.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "keywords": [
    "thai",
    "address",
    "thailand",
    "zipcode",
    "province",
    "district",
    "subDistrict",
    "thai-address",
    "thai-location",
    "location",
    "postal-code",
    "postcode",
    "tambon",
    "amphoe",
    "changwat",
    "bangkok",
    "ที่อยู่",
    "ประเทศไทย",
    "รหัสไปรษณีย์",
    "ตำบล",
    "อำเภอ",
    "จังหวัด",
    "autocomplete"
  ],
  "author": "KriZad",
  "license": "MIT",
  "homepage": "https://krizad.github.io/thai-address-demo/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KriZad/thai-address-helper-package.git"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "vitest related --run",
      "bash -c 'tsc --noEmit'"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "tsup": "^8.5.1",
    "typescript": "^5.4.5",
    "vitest": "^4.1.9"
  }
}
